# ====================================
# إعدادات التطبيق | Application Settings
# ====================================

NODE_ENV=development
PORT=5000
API_VERSION=v1

# ====================================
# قاعدة البيانات | Database
# ====================================

DATABASE_URL="postgresql://postgres:123456@localhost:5432/postgres?schema=public"

# ====================================
# المصادقة والأمان | Authentication & Security
# ====================================

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_characters
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# Bcrypt
BCRYPT_ROUNDS=12

# ====================================
# Redis - التخزين المؤقت | Caching
# ====================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ====================================
# البريد الإلكتروني | Email Configuration
# ====================================

EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_thx3606@gmail.com
EMAIL_PASSWORD=Mm@112233
EMAIL_FROM=نظام مدارس القرآن <thx3606@gmail.com>

# ====================================
# WhatsApp - Twilio
# ====================================

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_ENABLED=false

# ====================================
# تحميل الملفات | File Upload
# ====================================

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,audio/mpeg,audio/wav

# ====================================
# الشهادات | Certificates
# ====================================

CERTIFICATE_DIR=./certificates
CERTIFICATE_LOGO_PATH=./assets/logo.png

# ====================================
# التقارير | Reports
# ====================================

REPORTS_DIR=./reports

# ====================================
# Frontend URL
# ====================================

FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,https://yuseer-backend.vercel.app

# ====================================
# الإشعارات | Notifications
# ====================================

NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_WHATSAPP_ENABLED=false

# ====================================
# نظام السجلات | Logging
# ====================================

LOG_LEVEL=debug
LOG_DIR=./logs

# ====================================
# Rate Limiting
# ====================================

RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# Session
# ====================================

SESSION_SECRET=your_session_secret_change_this_in_production
SESSION_MAX_AGE=86400000

# ====================================
# Admin Account (Initial Setup)
# ====================================

ADMIN_EMAIL=admin@quranschools.com
ADMIN_PASSWORD=Change@Admin123
ADMIN_FIRST_NAME=مدير
ADMIN_LAST_NAME=النظام

# ====================================
# تخصيص النظام | System Customization
# ====================================

SYSTEM_NAME_AR=نظام إدارة مدارس تحفيظ القرآن
SYSTEM_NAME_EN=Quranic Schools Management System
ORGANIZATION_NAME=مؤسسة القرآن الكريم

# ====================================
# واجهات برمجية خارجية | External APIs
# ====================================

# Quran API
QURAN_API_URL=https://api.alquran.cloud/v1

# Hijri Date API
HIJRI_API_URL=https://api.aladhan.com/v1

# ====================================
# أخرى | Miscellaneous
# ====================================

TIMEZONE=Asia/Riyadh
DEFAULT_LANGUAGE=ar
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100
